<div id="sbConfirmOverlay" class="sb-confirm-overlay" hidden>
    <div class="sb-confirm-dialog" role="dialog" aria-modal="true" aria-labelledby="sbConfirmTitle">
        <div class="sb-confirm-header">
            <div id="sbConfirmTitle" class="sb-confirm-title">Confirm</div>
            @* <button type="button" class="sb-confirm-close" aria-label="Close" data-sb-confirm-cancel>&times;</button> *@
        </div>
        <div id="sbConfirmMessage" class="sb-confirm-message">
            Are you sure?
        </div>
        <div class="sb-confirm-actions">
            <button type="button" class="sb-confirm-btn sb-confirm-btn-secondary" data-sb-confirm-cancel>Keep Editing</button>
            <button type="button" class="sb-confirm-btn sb-confirm-btn-danger" data-sb-confirm-ok>Discard</button>
        </div>
    </div>
</div>

