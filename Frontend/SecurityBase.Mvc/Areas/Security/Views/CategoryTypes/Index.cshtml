@using SecurityBase.Mvc.Helpers
@{
    ViewData["Title"] = "Category Type Management";
    var permissions = MenuPermissionHelper.GetMenuPermissions(Context, "/Security/CategoryTypes/Index");
}

<div class="container-fluid p-2 grid-page">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary"><i class="fas fa-tags me-2"></i>Category Type Management</h2>
        </div>
        <div class="col-md-6 text-end">
            <div class="patient-table-actions">
                <div class="searchbar" style="display:inline-block;">
                    <div class="searchbar-wrapper">
                        <div class="searchbar-left">
                            <div class="search-icon-wrapper">
                                <span class="search-icon searchbar-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>

                        <div class="searchbar-center">
                            <div class="searchbar-input-spacer"></div>
                            <input type="text" id="categoryTypeSearch" class="searchbar-input" maxlength="2048" autocapitalize="off" autocomplete="off" title="Search" role="combobox" placeholder="Search category types...">
                        </div>
                    </div>
                </div>
                <button class="button" type="button"><i class="fa-solid fa-file-export pe-1"></i> Export</button>
                @if (permissions.CanCreate)
                {
                    <button class="button" type="button" onclick="openCreateModal()">
                        <i class="fa-solid fa-plus pe-1"></i> Add Category Type
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="patient-table-responsive shadow-sm grid-card">
        <div class="grid-table-wrap">
            <table class="patient-table" id="categoryTypesTable">
                <thead>
                    <tr>
                        <th style="width: 25%;">Type Name</th>
                        <th style="width: 30%;">Description</th>
                        <th style="width: 15%;">Status</th>
                        <th style="width: 10%;">Order</th>
                        <th style="width: 20%;" class="cell-actions">Categories</th>
                        @if (permissions.CanEdit || permissions.CanDelete)
                        {
                            <th style="width: 10%;" class="cell-actions">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="@(permissions.CanEdit || permissions.CanDelete ? 6 : 5)" class="text-center p-5">
                            <div class="text-muted">
                                <i class="fas fa-spinner fa-spin fa-2x mb-3"></i>
                                <p class="mb-0">Loading category types...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="patient-table-pagination-bar">
            <div class="pagination-info">
                Showing <span id="categoryTypesShownCount">0</span> entries
            </div>
            <div class="pagination-controls">
                <select class="page-size-selector" id="categoryTypesPageSize">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="-1">All</option>
                </select>
                <button class="button-3d" onclick="loadCategoryTypes()" title="Refresh">
                    <div class="button-top">
                        <span class="material-icons"><i class="fas fa-sync-alt m-0"></i></span>
                    </div>
                    <div class="button-bottom"></div>
                    <div class="button-base"></div>
                </button>
                <div class="button-container">
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10094;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                    <span class="page-number">Page 1 of 1</span>
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10095;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade sb-modal" id="categoryTypeModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header sb-form-modal-header">
                <div>
                    <h5 class="modal-title" id="categoryTypeModalTitle">Add Category Type</h5>
                    <div class="sb-form-modal-subtitle">Define a reusable category type</div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" data-sb-modal-close></button>
            </div>
            <div class="modal-body p-4 sb-form-modal-body">
                <form id="categoryTypeForm" class="sb-form" novalidate>
                    <input type="hidden" id="categoryTypeId" name="CategoryTypeId" value="0" />
                    <div class="form-section mb-0">
                        <div class="section-title">
                            <i class="fas fa-layer-group section-icon"></i>
                            Category Type Details
                        </div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label">
                                    Type Name <span class="text-danger">*</span>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-tag input-icon"></i>
                                    <input type="text" id="categoryTypeName" name="CategoryTypeName" class="form-control" placeholder="Type name" required />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">Description</label>
                                <div class="input-with-icon">
                                    <i class="fas fa-align-left input-icon"></i>
                                    <input type="text" id="categoryTypeDescription" name="Description" class="form-control" placeholder="Short description" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Display Order</label>
                                <div class="input-with-icon">
                                    <i class="fas fa-sort-numeric-down input-icon"></i>
                                    <input type="number" id="categoryTypeDisplayOrder" name="DisplayOrder" class="form-control" value="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <div class="form-check form-switch p-3 bg-light rounded-3 mb-0">
                                    <input type="checkbox" id="categoryTypeIsActive" name="IsActive" value="true" class="form-check-input ms-0" checked />
                                    <input type="hidden" id="categoryTypeIsActiveHidden" name="IsActive" value="false" />
                                    <label class="form-check-label ms-2 fw-bold" for="categoryTypeIsActive">Active</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer sb-form-actions">
                <div class="sb-form w-100 d-flex justify-content-end align-items-center gap-2">
                    <button type="button" class="btn-cancel" data-sb-modal-close>
                        <span>CANCEL</span>
                    </button>
                    <button type="button" class="btn-save" onclick="saveCategoryType()">
                        <span class="shadow"></span>
                        <span class="edge"></span>
                        <span class="front"><span>SAVE</span></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allCategoryTypes = [];
        var canEdit = @(permissions.CanEdit ? "true" : "false");
        var canDelete = @(permissions.CanDelete ? "true" : "false");
        var hasActions = canEdit || canDelete;
        var colSpan = hasActions ? 6 : 5;

        function loadCategoryTypes() {
            $.ajax({
                url: '/Security/CategoryTypes/GetAllCategoryTypes',
                type: 'GET',
                success: function (response) {
                    allCategoryTypes = response.data || [];
                    applyCategoryTypesGrid();
                },
                error: function () {
                    $('#categoryTypesTable tbody').html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-exclamation-triangle fa-2x mb-3"></i><p>Failed to load category types.</p></div></td></tr>');
                }
            });
        }

        function renderCategoryTypesTable(items) {
            var $tbody = $('#categoryTypesTable tbody');
            $tbody.empty();

            if (!items || items.length === 0) {
                $tbody.html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-search fa-2x mb-3"></i><p class="mb-0">No category types found.</p></div></td></tr>');
                return;
            }

            $.each(items, function (i, item) {
                var id = item.categoryTypeId || item.CategoryTypeId || 0;
                var name = item.categoryTypeName || item.CategoryTypeName || '';
                var desc = item.description || item.Description || '';
                var isActive = (item.isActive != null ? item.isActive : item.IsActive) ? true : false;
                var order = item.displayOrder != null ? item.displayOrder : (item.DisplayOrder != null ? item.DisplayOrder : 0);

                var row = '<tr>';
                row += '<td><i class="fas fa-tag text-warning me-2"></i><span class="fw-bold text-dark">' + $('<span>').text(name).html() + '</span></td>';
                row += '<td>' + $('<span>').text(desc).html() + '</td>';
                row += '<td><span class="patient-badge patient-badge-' + (isActive ? 'success' : 'secondary') + '">' + (isActive ? 'Active' : 'Inactive') + '</span></td>';
                row += '<td><span class="badge bg-light text-dark">' + order + '</span></td>';
                row += '<td class="cell-actions"><button class="button js-view-categories" type="button" data-type-id="' + id + '" data-type-name="' + $('<span>').text(name).html() + '"><i class="fas fa-folder-open pe-1"></i> View</button></td>';

                if (hasActions) {
                    row += '<td class="cell-actions">';
                    if (canEdit) {
                        row += '<button onclick=\'editCategoryType(' + JSON.stringify(item) + ')\' class="patient-table-action patient-table-edit" title="Edit"><i class="fas fa-edit"></i></button>';
                    }
                    if (canDelete) {
                        row += '<button onclick="deleteCategoryType(' + id + ')" class="patient-table-action patient-table-delete" title="Delete"><i class="fas fa-trash"></i></button>';
                    }
                    row += '</td>';
                }
                row += '</tr>';
                $tbody.append(row);
            });
        }

        function applyCategoryTypesGrid() {
            var query = (($('#categoryTypeSearch').val() || '') + '').toLowerCase();
            var pageSizeRaw = parseInt($('#categoryTypesPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;

            var filtered = allCategoryTypes.filter(function (m) {
                if (!query) return true;
                var text = ((m.categoryTypeName || m.CategoryTypeName || '') + ' ' + (m.description || m.Description || '')).toLowerCase();
                return text.indexOf(query) > -1;
            });

            if (pageSize > 0) {
                filtered = filtered.slice(0, pageSize);
            }

            renderCategoryTypesTable(filtered);
            $('#categoryTypesShownCount').text(filtered.length);
        }

        function openCreateModal() {
            $('#categoryTypeForm')[0].reset();
            $('#categoryTypeId').val(0);
            $('#categoryTypeModalTitle').text('Add Category Type');
            $('#categoryTypeIsActive').prop('checked', true);
            updateCategoryTypeIsActiveHidden();
            $('#categoryTypeModal').modal('show');
        }

        function editCategoryType(item) {
            var id = item.categoryTypeId || item.CategoryTypeId || 0;
            var name = item.categoryTypeName || item.CategoryTypeName || '';
            var desc = item.description || item.Description || '';
            var isActive = (item.isActive != null ? item.isActive : item.IsActive) ? true : false;
            var order = item.displayOrder != null ? item.displayOrder : (item.DisplayOrder != null ? item.DisplayOrder : 0);

            $('#categoryTypeModalTitle').text('Edit Category Type');
            $('#categoryTypeId').val(id);
            $('#categoryTypeName').val(name);
            $('#categoryTypeDescription').val(desc);
            $('#categoryTypeDisplayOrder').val(order);
            $('#categoryTypeIsActive').prop('checked', !!isActive);
            updateCategoryTypeIsActiveHidden();
            $('#categoryTypeModal').modal('show');
        }

        function updateCategoryTypeIsActiveHidden() {
            var isChecked = !!$('#categoryTypeIsActive').is(':checked');
            $('#categoryTypeIsActiveHidden').prop('disabled', isChecked);
        }

        function saveCategoryType() {
            if (window.SBFormValidation && !window.SBFormValidation.validateCategoryTypeForm()) return;
            var formData = $('#categoryTypeForm').serialize();

            $.post('/Security/CategoryTypes/SaveCategoryType', formData, function (response) {
                if (response && response.success) {
                    if (window.SBToast) window.SBToast.success((response.message || 'Saved.'));
                    if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.allowCloseOnce('categoryTypeModal');
                    loadCategoryTypes();
                    $('#categoryTypeModal').modal('hide');
                } else {
                    if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Save failed.');
                }
            });
        }

        function deleteCategoryType(id) {
            if (!window.SBToast || !window.SBToast.confirm) return;

            window.SBToast.confirm({ title: 'Delete category type', message: "Delete this category type?", variant: 'danger', confirmText: 'Delete' })
                .then(function (ok) {
                    if (!ok) return;
                    $.ajax({
                        url: '/Security/CategoryTypes/DeleteCategoryType/' + id,
                        type: 'DELETE',
                        success: function (response) {
                            if (response && response.success) {
                                window.SBToast.success((response.message || 'Deleted.'));
                                loadCategoryTypes();
                            } else {
                                window.SBToast.error((response && response.message) ? response.message : 'Delete failed.');
                            }
                        }
                    });
                });
        }

        $('#categoryTypeSearch').on('keyup', applyCategoryTypesGrid);
        $('#categoryTypesPageSize').on('change', applyCategoryTypesGrid);
        $(document).ready(function () {
            if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.attach({ modalId: 'categoryTypeModal', formId: 'categoryTypeForm' });
            $('#categoryTypeIsActive').on('change', updateCategoryTypeIsActiveHidden);
            updateCategoryTypeIsActiveHidden();
            loadCategoryTypes();
        });

        function viewCategories(typeId, typeName) {
            var url = '/Security/Categories/Index?typeId=' + encodeURIComponent(typeId || '');
            if (typeName) {
                url += '&typeName=' + encodeURIComponent(typeName);
            }
            window.location.href = url;
        }

        $(document).on('click', '.js-view-categories', function () {
            var typeId = $(this).data('type-id');
            var typeName = $(this).data('type-name');
            viewCategories(typeId, typeName);
        });
    </script>
}
