@using SecurityBase.Mvc.Helpers
@{
    ViewData["Title"] = "User Management";

    var permissions = MenuPermissionHelper.GetMenuPermissions(Context, "/Security/Users/Index");
    var canCreate = permissions.CanCreate;
    var canEdit = permissions.CanEdit;
    var canDelete = permissions.CanDelete;
    var hasActions = canEdit || canDelete;
}

<div class="container-fluid p-2 grid-page">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary"><i class="fas fa-users-cog me-2"></i>User Management</h2>
        </div>
        <div class="col-md-6 text-end">
            <div class="patient-table-actions">
                <div class="searchbar" style="display:inline-block;">
                    <div class="searchbar-wrapper">
                        <div class="searchbar-left">
                            <div class="search-icon-wrapper">
                                <span class="search-icon searchbar-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="searchbar-center">
                            <div class="searchbar-input-spacer"></div>
                            <input type="text" id="userSearch" class="searchbar-input" maxlength="2048" autocapitalize="off" autocomplete="off" title="Search" role="combobox" placeholder="Search users...">
                        </div>
                    </div>
                </div>
                <button class="button" type="button"><i class="fa-solid fa-file-export pe-1"></i> Export</button>
                @if (canCreate)
                {
                    <button class="button" type="button" onclick="openCreateModal()">
                        <i class="fa-solid fa-plus pe-1"></i> Add User
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="patient-table-responsive shadow-sm grid-card">
        <div class="grid-table-wrap">
            <table class="patient-table" id="usersTable">
                <thead>
                    <tr>
                        <th style="width: 20%;">Username</th>
                        <th style="width: 30%;">Email</th>
                        <th style="width: 20%;">Created Date</th>
                        <th style="width: 15%;">Status</th>
                        @if (hasActions)
                        {
                            <th style="width: 15%;">Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="@(hasActions ? 5 : 4)" class="text-center p-5">
                            <div class="text-muted">
                                <i class="fas fa-spinner fa-spin fa-2x mb-3"></i>
                                <p class="mb-0">Loading users...</p>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="patient-table-pagination-bar">
            <div class="pagination-info">
                Showing <span id="usersShownCount">0</span> entries
            </div>
            <div class="pagination-controls">
                <select class="page-size-selector" id="usersPageSize">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="-1">All</option>
                </select>
                <button class="button-3d" onclick="loadUsers()" title="Refresh">
                    <div class="button-top">
                        <span class="material-icons"><i class="fas fa-sync-alt m-0"></i></span>
                    </div>
                    <div class="button-bottom"></div>
                    <div class="button-base"></div>
                </button>
                <div class="button-container">
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10094;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                    <span class="page-number">Page 1 of 1</span>
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10095;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade sb-modal" id="userModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header sb-form-modal-header">
                <div>
                    <h5 class="modal-title" id="modalTitle">Add User</h5>
                    <div class="sb-form-modal-subtitle">Enter user account details</div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" data-sb-modal-close></button>
            </div>
            <div class="modal-body p-4 sb-form-modal-body">
                <form id="userForm" class="sb-form" novalidate>
                    <input type="hidden" id="userId" name="UserId" value="0" />
                    <div class="form-section">
                        <div class="section-title">
                            <i class="fas fa-user-circle section-icon"></i>
                            Account Information
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">
                                    Username <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="3–30 characters. Allowed: letters, numbers, dot (.), underscore (_) and hyphen (-)." aria-label="Username requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-user input-icon"></i>
                                    <input type="text" id="username" name="Username" class="form-control" placeholder="Username" required />
                                </div>
                            </div>
                            <div class="col-md-6" id="passwordGroup">
                                <label class="form-label">
                                    Password <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Minimum 8 characters, with uppercase + lowercase + number + symbol. No spaces." aria-label="Password requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-lock input-icon"></i>
                                    <input type="password" id="passwordHash" name="PasswordHash" class="form-control" placeholder="Password" />
                                </div>
                                <div class="sb-password-meter">
                                    <div id="passwordMeterBar" class="sb-password-meter-bar" data-score="0"></div>
                                </div>
                                @* <div id="passwordStrengthText" class="sb-password-text">Use 8+ chars with upper/lower/number/symbol (no spaces).</div> *@
                            </div>
                            <div class="col-12 d-none" id="passwordEditTools">
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="togglePasswordEdit()">
                                    <i class="fas fa-key me-1"></i><span id="passwordEditBtnText">Change password</span>
                                </button>
                                <div class="small text-muted mt-1">For security, the current password is never shown. Enter a new password to reset it.</div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">
                                    Email <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Enter a valid email address (example: name@domain.com)." aria-label="Email requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-envelope input-icon"></i>
                                    <input type="email" id="email" name="Email" class="form-control" placeholder="name@company.com" required />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="form-section mb-0">
                        <div class="section-title">
                            <i class="fas fa-toggle-on section-icon"></i>
                            Status
                        </div>
                        <div class="form-check form-switch p-3 bg-light rounded-3 mb-0">
                            <input type="checkbox" id="isActive" name="IsActive" value="true" class="form-check-input ms-0" checked />
                            <input type="hidden" id="isActiveHidden" name="IsActive" value="false" />
                            <label class="form-check-label ms-2 fw-bold" for="isActive">Account Active</label>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer sb-form-actions">
                <div class="sb-form w-100 d-flex justify-content-end align-items-center gap-2">
                    <button type="button" class="btn-cancel" data-sb-modal-close>
                        <span>CANCEL</span>
                    </button>
                    <button type="button" class="btn-save" onclick="saveUser()">
                        <span class="shadow"></span>
                        <span class="edge"></span>
                        <span class="front"><span>SAVE</span></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allUsers = [];
        var canEdit = @(canEdit ? "true" : "false");
        var canDelete = @(canDelete ? "true" : "false");
        var hasActions = @(hasActions ? "true" : "false");

        function toBool(v) {
            if (v === true || v === 1) return true;
            if (v === false || v === 0 || v == null) return false;
            if (typeof v === 'string') {
                var s = v.trim().toLowerCase();
                if (s === '1' || s === 'true' || s === 'yes' || s === 'on') return true;
                if (s === '0' || s === 'false' || s === 'no' || s === 'off' || s === '') return false;
            }
            return !!v;
        }

        function loadUsers() {
            $.ajax({
                url: '/Security/Users/GetAllUsers',
                type: 'GET',
                data: { draw: 1, start: 0, length: 1000 },
                success: function (response) {
                    allUsers = response.data || [];
                    applyUsersGrid();
                },
                error: function () {
                    $('#usersTable tbody').html('<tr><td colspan="' + (hasActions ? 5 : 4) + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-exclamation-triangle fa-2x mb-3"></i><p>Failed to load users.</p></div></td></tr>');
                }
            });
        }

        function renderUsersTable(users) {
            var $tbody = $('#usersTable tbody');
            $tbody.empty();

            if (!users || users.length === 0) {
                $tbody.html('<tr><td colspan="' + (hasActions ? 5 : 4) + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-search fa-2x mb-3"></i><p>No users found.</p></div></td></tr>');
                return;
            }

            $.each(users, function (i, user) {
                var userId = user.userId || user.UserId || 0;
                var username = user.username || user.Username || '';
                var email = user.email || user.Email || '';
                var isActive = toBool(user.isActive != null ? user.isActive : user.IsActive);
                var createdDate = user.createdDate || user.CreatedDate || '';
                if (createdDate) {
                    var d = new Date(createdDate);
                    createdDate = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
                }

                var row = '<tr>';
                row += '<td><i class="fas fa-user-circle text-muted me-2"></i><span class="fw-bold text-dark">' + $('<span>').text(username).html() + '</span></td>';
                row += '<td>' + $('<span>').text(email).html() + '</td>';
                row += '<td>' + createdDate + '</td>';
                row += '<td><span class="patient-badge patient-badge-' + (isActive ? 'success' : 'secondary') + '">' + (isActive ? 'Active' : 'Inactive') + '</span></td>';

                if (hasActions) {
                    row += '<td>';
                    if (canEdit) {
                        row += '<button onclick=\'editUser(' + JSON.stringify(user) + ')\' class="patient-table-action patient-table-edit" title="Edit"><i class="fas fa-edit"></i></button>';
                    }
                    if (canDelete) {
                        row += '<button onclick="deleteUser(' + userId + ')" class="patient-table-action patient-table-delete" title="Delete"><i class="fas fa-trash"></i></button>';
                    }
                    row += '</td>';
                }
                row += '</tr>';
                $tbody.append(row);
            });
        }

        function applyUsersGrid() {
            var query = (($('#userSearch').val() || '') + '').toLowerCase();
            var pageSizeRaw = parseInt($('#usersPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;

            var filtered = allUsers.filter(function (u) {
                if (!query) return true;
                var text = ((u.username || u.Username || '') + ' ' + (u.email || u.Email || '')).toLowerCase();
                return text.indexOf(query) > -1;
            });

            if (pageSize > 0) {
                filtered = filtered.slice(0, pageSize);
            }

            renderUsersTable(filtered);
            $('#usersShownCount').text(filtered.length);
        }

        function openCreateModal() {
            $('#modalTitle').text('Add User');
            $('#userForm')[0].reset();
            if (window.SBFormValidation) window.SBFormValidation.clearErrors(document.getElementById('userForm'));
            $('#userId').val('0');
            $('#passwordGroup').show();
            $('#passwordHash').prop('required', true);
            $('#passwordHash').attr('placeholder', 'Password');
            $('#passwordEditTools').addClass('d-none');
            $('#passwordEditBtnText').text('Change password');
            if (window.SBFormValidation) window.SBFormValidation.updatePasswordMeter(document.getElementById('passwordHash'), document.getElementById('passwordMeterBar'), document.getElementById('passwordStrengthText'));
            updateIsActiveHidden();
            $('#userModal').modal('show');
        }

        function togglePasswordEdit() {
            var isVisible = !!($('#passwordGroup').is(':visible'));
            if (isVisible) {
                $('#passwordHash').val('');
                $('#passwordGroup').hide();
                $('#passwordHash').prop('required', false);
                $('#passwordEditBtnText').text('Change password');
            } else {
                $('#passwordGroup').show();
                $('#passwordHash').prop('required', true);
                $('#passwordHash').attr('placeholder', 'New password');
                $('#passwordEditBtnText').text('Cancel password change');
                var pwd = document.getElementById('passwordHash');
                if (pwd && window.SBFormValidation) window.SBFormValidation.updatePasswordMeter(pwd, document.getElementById('passwordMeterBar'), document.getElementById('passwordStrengthText'));
                setTimeout(function () { $('#passwordHash').trigger('focus'); }, 50);
            }
        }

        function editUser(user) {
            var userId = user && user.userId != null ? user.userId : (user && user.UserId != null ? user.UserId : 0);
            var username = user && user.username != null ? user.username : (user && user.Username != null ? user.Username : '');
            var email = user && user.email != null ? user.email : (user && user.Email != null ? user.Email : '');
            var isActive = toBool(user && user.isActive != null ? user.isActive : (user ? user.IsActive : false));

            $('#modalTitle').text('Edit User');
            $('#userId').val(userId);
            $('#username').val(username);
            $('#email').val(email);
            $('#isActive').prop('checked', !!isActive);
            updateIsActiveHidden();
            $('#passwordHash').val('');
            $('#passwordGroup').hide();
            $('#passwordHash').prop('required', false);
            $('#passwordEditTools').removeClass('d-none');
            $('#passwordEditBtnText').text('Change password');
            if (window.SBFormValidation) window.SBFormValidation.clearErrors(document.getElementById('userForm'));
            $('#userModal').modal('show');
        }

        function updateIsActiveHidden() {
            var isChecked = !!$('#isActive').is(':checked');
            // Prevent sending both true+false; send only one value.
            $('#isActiveHidden').prop('disabled', isChecked);
        }

        function saveUser() {
            if (window.SBFormValidation && !window.SBFormValidation.validateUserForm()) return;
            var formData = $('#userForm').serialize();

            $.post('/Security/Users/SaveUser', formData, function (response) {
                if (response && response.success) {
                    if (window.SBToast) window.SBToast.success((response.message || 'Saved.'));
                    if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.allowCloseOnce('userModal');
                    loadUsers();
                    $('#userModal').modal('hide');
                } else {
                    if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Save failed.');
                }
            });
        }

        function deleteUser(id) {
            if (!window.SBToast || !window.SBToast.confirm) return;

            window.SBToast.confirm({ title: 'Delete user', message: "Delete this user? This can't be undone.", variant: 'danger', confirmText: 'Delete' })
                .then(function (ok) {
                    if (!ok) return;
                    $.ajax({
                        url: '/Security/Users/DeleteUser/' + id,
                        type: 'DELETE',
                        success: function (response) {
                            if (response && response.success) {
                                window.SBToast.success((response.message || 'Deleted.'));
                                loadUsers();
                            } else {
                                window.SBToast.error((response && response.message) ? response.message : 'Delete failed.');
                            }
                        }
                    });
                });
        }

        $('#userSearch').on('keyup', applyUsersGrid);
        $('#usersPageSize').on('change', applyUsersGrid);
        $(document).ready(function () {
            if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.attach({ modalId: 'userModal', formId: 'userForm' });
            $('#isActive').on('change', updateIsActiveHidden);
            var pwd = document.getElementById('passwordHash');
            if (pwd && window.SBFormValidation) {
                pwd.addEventListener('input', function () {
                    window.SBFormValidation.updatePasswordMeter(pwd, document.getElementById('passwordMeterBar'), document.getElementById('passwordStrengthText'));
                });
            }
            updateIsActiveHidden();
            loadUsers();
        });
    </script>
}
