@using SecurityBase.Mvc.Helpers
@{
    ViewData["Title"] = "Menu Management";
    var permissions = MenuPermissionHelper.GetMenuPermissions(Context, "/Security/Menus/Index");
}

<div class="container-fluid p-2 grid-page">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary"><i class="fas fa-list-alt me-2"></i>Menu Management</h2>
        </div>
        <div class="col-md-6 text-end">
            <div class="patient-table-actions">
                <div class="searchbar" style="display:inline-block;">
                    <div class="searchbar-wrapper">
                        <div class="searchbar-left">
                            <div class="search-icon-wrapper">
                                <span class="search-icon searchbar-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>

                        <div class="searchbar-center">
                            <div class="searchbar-input-spacer"></div>
                            <input type="text" id="menuSearch" class="searchbar-input" maxlength="2048" autocapitalize="off" autocomplete="off" title="Search" role="combobox" placeholder="Search menus...">
                        </div>
                    </div>
                </div>
                <button class="button" type="button"><i class="fa-solid fa-file-export pe-1"></i> Export</button>
                @if (permissions.CanCreate)
                {
                    <button class="button" type="button" onclick="openCreateModal()">
                        <i class="fa-solid fa-plus pe-1"></i> Add Menu
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="patient-table-responsive shadow-sm grid-card">
        <div class="grid-table-wrap">
        <table class="patient-table" id="menusTable">
            <thead>
                <tr>
                    <th style="width: 25%;">Menu Name</th>
                    <th style="width: 25%;">Route</th>
                    <th style="width: 20%;">Icon</th>
                    <th style="width: 10%;">Order</th>
                    @if (permissions.CanEdit || permissions.CanDelete)
                    {
                        <th style="width: 20%;">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="@(permissions.CanEdit || permissions.CanDelete ? 5 : 4)" class="text-center p-5">
                        <div class="text-muted">
                            <i class="fas fa-spinner fa-spin fa-2x mb-3"></i>
                            <p class="mb-0">Loading menus...</p>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
        </div>
        <div class="patient-table-pagination-bar">
            <div class="pagination-info">
                Showing <span id="menusShownCount">0</span> entries
            </div>
            <div class="pagination-controls">
                <select class="page-size-selector" id="menusPageSize">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="-1">All</option>
                </select>
                <button class="button-3d" onclick="loadMenus()" title="Refresh">
                    <div class="button-top">
                        <span class="material-icons"><i class="fas fa-sync-alt m-0"></i></span>
                    </div>
                    <div class="button-bottom"></div>
                    <div class="button-base"></div>
                </button>
                <div class="button-container">
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10094;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                    <span class="page-number">Page 1 of 1</span>
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10095;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade sb-modal" id="menuModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header sb-form-modal-header">
                <div>
                    <h5 class="modal-title" id="modalTitle">Add Menu</h5>
                    <div class="sb-form-modal-subtitle">Configure navigation menu properties</div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" data-sb-modal-close></button>
            </div>
            <div class="modal-body p-4 sb-form-modal-body">
                <form id="menuForm" class="sb-form" novalidate>
                    <input type="hidden" id="menuId" name="MenuId" value="0" />
                    <div class="form-section mb-0">
                        <div class="section-title">
                            <i class="fas fa-layer-group section-icon"></i>
                            Menu Details
                        </div>
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label class="form-label">
                                    Menu Name <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="2–60 characters." aria-label="Menu name requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-folder input-icon"></i>
                                    <input type="text" id="menuName" name="MenuName" class="form-control" placeholder="Menu name" required />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">
                                    Route
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Optional. If set, start with “/” (example: /Security/Users/Index)." aria-label="Route requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-link input-icon"></i>
                                    <input type="text" id="route" name="Route" class="form-control" placeholder="/Controller/Action" />
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label">
                                    Icon (FontAwesome)
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Optional. Example: fas fa-user (FontAwesome class list)." aria-label="Icon requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-icons input-icon"></i>
                                    <input type="text" id="icon" name="Icon" class="form-control" placeholder="e.g. fas fa-user" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Display Order
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Integer between 0 and 9999." aria-label="Display order requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-sort-numeric-down input-icon"></i>
                                    <input type="number" id="displayOrder" name="DisplayOrder" class="form-control" value="0" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">
                                    Menu Type <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Choose Parent for top-level menus or Child to place it under a parent menu." aria-label="Menu type info">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-diagram-project input-icon"></i>
                                    <select id="menuType" name="MenuType" class="form-select">
                                        <option value="">Select menu type</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-12 d-none" id="parentMenuGroup">
                                <label class="form-label">
                                    Parent Menu <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Select the parent menu for this child." aria-label="Parent menu info">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-sitemap input-icon"></i>
                                    <select id="parentMenuId" name="ParentMenuId" class="form-select" disabled>
                                        <option value="">Select parent menu</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer sb-form-actions">
                <div class="sb-form w-100 d-flex justify-content-end align-items-center gap-2">
                    <button type="button" class="btn-cancel" data-sb-modal-close>
                        <span>CANCEL</span>
                    </button>
                    <button type="button" class="btn-save" onclick="saveMenu()">
                        <span class="shadow"></span>
                        <span class="edge"></span>
                        <span class="front"><span>SAVE</span></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allMenus = [];
        var canEdit = @(permissions.CanEdit ? "true" : "false");
        var canDelete = @(permissions.CanDelete ? "true" : "false");
        var hasActions = canEdit || canDelete;
        var colSpan = hasActions ? 5 : 4;

        function loadMenus() {
            $.ajax({
                url: '/Security/Menus/GetAllMenus',
                type: 'GET',
                success: function (response) {
                    allMenus = response.data || [];
                    applyMenusGrid();
                },
                error: function () {
                    $('#menusTable tbody').html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-exclamation-triangle fa-2x mb-3"></i><p>Failed to load menus.</p></div></td></tr>');
                }
            });
        }

        function renderMenusTable(menus) {
            var $tbody = $('#menusTable tbody');
            $tbody.empty();

            if (!menus || menus.length === 0) {
                $tbody.html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-search fa-2x mb-3"></i><p class="mb-0">No menus found.</p></div></td></tr>');
                return;
            }

            $.each(menus, function (i, menu) {
                var menuId = menu.menuId || menu.MenuId || 0;
                var menuName = menu.menuName || menu.MenuName || '';
                var route = menu.route || menu.Route || '';
                var icon = menu.icon || menu.Icon || '';
                var displayOrder = menu.displayOrder != null ? menu.displayOrder : (menu.DisplayOrder != null ? menu.DisplayOrder : 0);

                var row = '<tr>';
                row += '<td><i class="fas fa-folder text-warning me-2"></i><span class="fw-bold text-dark">' + $('<span>').text(menuName).html() + '</span></td>';
                row += '<td><code class="text-primary">' + $('<span>').text(route).html() + '</code></td>';
                row += '<td><i class="' + $('<span>').text(icon).html() + ' me-2"></i> <span class="small text-muted">' + $('<span>').text(icon).html() + '</span></td>';
                row += '<td><span class="badge bg-light text-dark">' + displayOrder + '</span></td>';

                if (hasActions) {
                    row += '<td>';
                    if (canEdit) {
                        row += '<button onclick=\'editMenu(' + JSON.stringify(menu) + ')\' class="patient-table-action patient-table-edit" title="Edit"><i class="fas fa-edit"></i></button>';
                    }
                    if (canDelete) {
                        row += '<button onclick="deleteMenu(' + menuId + ')" class="patient-table-action patient-table-delete" title="Delete"><i class="fas fa-trash"></i></button>';
                    }
                    row += '</td>';
                }
                row += '</tr>';
                $tbody.append(row);
            });
        }

        function applyMenusGrid() {
            var query = (($('#menuSearch').val() || '') + '').toLowerCase();
            var pageSizeRaw = parseInt($('#menusPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;

            var filtered = allMenus.filter(function (m) {
                if (!query) return true;
                var text = ((m.menuName || m.MenuName || '') + ' ' + (m.route || m.Route || '')).toLowerCase();
                return text.indexOf(query) > -1;
            });

            if (pageSize > 0) {
                filtered = filtered.slice(0, pageSize);
            }

            renderMenusTable(filtered);
            $('#menusShownCount').text(filtered.length);
        }

        function openCreateModal() {
            $('#menuForm')[0].reset();
            $('#menuId').val(0);
            $('#modalTitle').text('Add Menu');
            loadMenuTypes('Parent');
            rebuildParentMenuOptions(0, '');
            $('#menuModal').modal('show');
        }

        function editMenu(menu) {
            var menuId = menu && menu.menuId != null ? menu.menuId : (menu && menu.MenuId != null ? menu.MenuId : 0);
            var menuName = menu && menu.menuName != null ? menu.menuName : (menu && menu.MenuName != null ? menu.MenuName : '');
            var route = menu && menu.route != null ? menu.route : (menu && menu.Route != null ? menu.Route : '');
            var icon = menu && menu.icon != null ? menu.icon : (menu && menu.Icon != null ? menu.Icon : '');
            var parentMenuId = menu && menu.parentMenuId != null ? menu.parentMenuId : (menu && menu.ParentMenuId != null ? menu.ParentMenuId : '');
            var displayOrder = menu && menu.displayOrder != null ? menu.displayOrder : (menu && menu.DisplayOrder != null ? menu.DisplayOrder : 0);

            $('#modalTitle').text('Edit Menu');
            $('#menuId').val(menuId);
            $('#menuName').val(menuName);
            $('#route').val(route);
            $('#icon').val(icon);
            $('#displayOrder').val(displayOrder);
            var isChild = parentMenuId != null && String(parentMenuId) !== '' && String(parentMenuId) !== '0';
            loadMenuTypes(isChild ? 'Child' : 'Parent');
            rebuildParentMenuOptions(menuId, isChild ? String(parentMenuId) : '');
            $('#menuModal').modal('show');
        }

        function getParentMenus(excludeMenuId) {
            excludeMenuId = excludeMenuId || 0;
            return (allMenus || []).filter(function (m) {
                var id = m.menuId != null ? m.menuId : m.MenuId;
                var pid = m.parentMenuId != null ? m.parentMenuId : m.ParentMenuId;
                var isTop = pid == null || String(pid) === '' || String(pid) === '0';
                return isTop && id && parseInt(id, 10) !== parseInt(excludeMenuId, 10);
            });
        }

        function rebuildParentMenuOptions(excludeMenuId, selectedParentId) {
            var $ddl = $('#parentMenuId');
            $ddl.empty();
            $ddl.append('<option value=\"\">Select parent menu</option>');

            var parents = getParentMenus(excludeMenuId)
                .slice()
                .sort(function (a, b) {
                    var ao = a.displayOrder != null ? a.displayOrder : (a.DisplayOrder != null ? a.DisplayOrder : 0);
                    var bo = b.displayOrder != null ? b.displayOrder : (b.DisplayOrder != null ? b.DisplayOrder : 0);
                    if (ao !== bo) return ao - bo;
                    var an = (a.menuName || a.MenuName || '').toLowerCase();
                    var bn = (b.menuName || b.MenuName || '').toLowerCase();
                    return an.localeCompare(bn);
                });

            parents.forEach(function (m) {
                var id = m.menuId != null ? m.menuId : m.MenuId;
                var name = m.menuName || m.MenuName || ('Menu ' + id);
                $ddl.append('<option value=\"' + id + '\">' + $('<span>').text(name).html() + '</option>');
            });

            if (selectedParentId != null && String(selectedParentId) !== '') {
                $ddl.val(String(selectedParentId));
            } else {
                $ddl.val('');
            }
        }

        function setMenuType(type) {
            var t = (type || 'Parent');
            $('#menuType').val(t);
            var isChild = t === 'Child';
            $('#parentMenuGroup').toggleClass('d-none', !isChild);
            $('#parentMenuId').prop('disabled', !isChild);
            $('#parentMenuId').prop('required', isChild);
            if (!isChild) $('#parentMenuId').val('');
        }

        function loadMenuTypes(selectedValue) {
            if (window.SBCategoryDropdowns && window.SBCategoryDropdowns.loadCategoriesByType) {
                return window.SBCategoryDropdowns.loadCategoriesByType('#menuType', 'MenuType', selectedValue, {
                    includeEmpty: true,
                    emptyLabel: 'Select menu type',
                    useNameAsValue: true,
                    fallback: [
                        { name: 'Parent' },
                        { name: 'Child' }
                    ]
                }).done(function () {
                    setMenuType($('#menuType').val() || selectedValue || 'Parent');
                });
            }

            var $ddl = $('#menuType');
            $ddl.empty();
            $ddl.append('<option value="">Select menu type</option>');
            $ddl.append('<option value="Parent">Parent</option>');
            $ddl.append('<option value="Child">Child</option>');
            if (selectedValue) $ddl.val(String(selectedValue));
            setMenuType($('#menuType').val() || selectedValue || 'Parent');
        }

        function saveMenu() {
            if (window.SBFormValidation && !window.SBFormValidation.validateMenuForm()) return;
            var formData = $('#menuForm').serialize();

            $.post('/Security/Menus/SaveMenu', formData, function (response) {
                if (response && response.success) {
                    if (window.SBToast) window.SBToast.success((response.message || 'Saved.'));
                    if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.allowCloseOnce('menuModal');
                    loadMenus();
                    $('#menuModal').modal('hide');
                } else {
                    if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Save failed.');
                }
            });
        }

        function deleteMenu(id) {
            if (!window.SBToast || !window.SBToast.confirm) return;

            window.SBToast.confirm({ title: 'Delete menu', message: "Delete this menu? This may impact access.", variant: 'danger', confirmText: 'Delete' })
                .then(function (ok) {
                    if (!ok) return;
                    $.ajax({
                        url: '/Security/Menus/DeleteMenu/' + id,
                        type: 'DELETE',
                        success: function (response) {
                            if (response && response.success) {
                                window.SBToast.success((response.message || 'Deleted.'));
                                loadMenus();
                            } else {
                                window.SBToast.error((response && response.message) ? response.message : 'Delete failed.');
                            }
                        }
                    });
                });
        }

        $('#menuSearch').on('keyup', applyMenusGrid);
        $('#menusPageSize').on('change', applyMenusGrid);
        $(document).ready(function () {
            if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.attach({ modalId: 'menuModal', formId: 'menuForm' });
            $('#menuType').on('change', function () {
                setMenuType($('#menuType').val());
                var menuId = parseInt($('#menuId').val() || '0', 10) || 0;
                rebuildParentMenuOptions(menuId, $('#parentMenuId').val());
            });
            loadMenus();
        });
    </script>
}
