@model SecurityBase.Core.DTOs.LoginRequest
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - SecurityBase</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/local-fonts.css" asp-append-version="true" />

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background-color: #ffffff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow-x: hidden;
            overflow-y: auto;
        }

        /* â”€â”€ MAIN CONTENT â”€â”€ */
        .page-body {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
            z-index: 1;
        }

        .login-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 30px 80px rgba(0,0,0,0.25);
            overflow: hidden;
            display: flex;
            flex-direction: row;
            width: 100%;
            max-width: 950px;
            min-height: 500px;
            animation: fadeInUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
            position: relative;
            z-index: 1;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(32px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* â”€â”€ LEFT ILLUSTRATION PANEL â”€â”€ */
        .illustration-panel {
            flex: 1.15;
            background: #f2f5ff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 32px;
            position: relative;
            overflow: hidden;
        }

            .illustration-panel::before {
                content: '';
                position: absolute;
                top: -60px;
                left: -60px;
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(123, 47, 247, 0.07);
            }

            .illustration-panel::after {
                content: '';
                position: absolute;
                bottom: -40px;
                right: -40px;
                width: 160px;
                height: 160px;
                border-radius: 50%;
                background: rgba(74, 144, 217, 0.08);
            }



        /* â”€â”€ RIGHT FORM PANEL â”€â”€ */
        .form-panel {
            flex: 0.9;
            padding: 56px 52px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: white;
        }

        .form-title {
            font-size: 32px;
            font-weight: 900;
            color: #1a1a2e;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 32px;
            text-align: center;
        }

        .field-wrapper {
            margin-bottom: 20px;
        }

        .input-row {
            display: flex;
            align-items: center;
            border: 1.8px solid #d6d9e6;
            border-radius: 10px;
            overflow: hidden;
            background: #fff;
            transition: border-color 0.25s, box-shadow 0.25s;
        }

            .input-row:focus-within {
                border-color: #7b2ff7;
                box-shadow: 0 0 0 3px rgba(123, 47, 247, 0.12);
            }

        .input-icon {
            width: 52px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #888;
            font-size: 15px;
            flex-shrink: 0;
        }

        .input-row input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 15px;
            font-family: 'Nunito', sans-serif;
            font-weight: 600;
            color: #333;
            padding: 14px 12px 14px 0;
            background: transparent;
        }

            .input-row input::placeholder {
                color: #aab0c0;
                font-weight: 500;
            }

        .password-toggle-btn {
            background: none;
            border: none;
            outline: none;
            cursor: pointer;
            color: #aab0c0;
            padding: 0 14px;
            font-size: 14px;
            transition: color 0.2s;
        }

            .password-toggle-btn:hover {
                color: #7b2ff7;
            }

        /* Remember me + Forgot password row */
        .form-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 28px;
            font-size: 14px;
        }

        .remember-label {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            color: #444;
            font-weight: 600;
        }

            .remember-label input[type="checkbox"] {
                width: 18px;
                height: 18px;
                accent-color: #7b2ff7;
                cursor: pointer;
            }

        .forgot-link {
            color: #555;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

            .forgot-link:hover {
                color: #7b2ff7;
            }

        /* LOGIN button */
        .btn-login {
            width: 100%;
            padding: 15px;
            background: #7b2ff7;
            border: none;
            border-radius: 10px;
            color: white;
            font-family: 'Nunito', sans-serif;
            font-size: 17px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.25s, transform 0.2s, box-shadow 0.25s;
            /* box-shadow: 0 6px 20px rgba(123, 47, 247, 0.35); */
        }

            .btn-login:hover {
                background: #6620e0;
                transform: translateY(-2px);
                /* box-shadow: 0 12px 28px rgba(123, 47, 247, 0.45); */
            }

            .btn-login:active {
                transform: translateY(0);
            }

        /* Alert */
        .alert {
            border-radius: 10px;
            font-size: 14px;
            border: none;
            padding: 14px 18px;
            margin-bottom: 20px;
            animation: slideDown 0.3s ease-out;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-danger {
            background: #dc3545;
            color: white;
        }

        .alert .btn-close {
            filter: brightness(0) invert(1);
        }

        /* â”€â”€ RESPONSIVE â”€â”€ */
        @@media (max-width: 900px) {
            .illustration-panel {
                display: none;
            }

            .form-panel {
                padding: 48px 40px;
                flex: 1;
            }

            .page-body {
                padding: 30px 20px;
            }
        }

        @@media (min-width: 769px) and (max-width: 900px) {
            .login-card {
                max-width: 560px;
            }
        }

        @@media (max-width: 768px) {
            .login-card {
                min-height: auto;
            }

            .form-panel {
                padding: 40px 35px;
            }

            .form-title {
                font-size: 28px;
                margin-bottom: 28px;
            }
        }

        @@media (max-width: 540px) {
            .page-body {
                padding: 20px 15px;
            }

            .login-card {
                border-radius: 16px;
            }

            .form-panel {
                padding: 35px 28px;
            }

            .form-title {
                font-size: 24px;
                margin-bottom: 24px;
            }

            .input-row input {
                font-size: 14px;
                padding: 13px 10px 13px 0;
            }

            .input-icon {
                width: 48px;
                font-size: 14px;
            }

            .btn-login {
                padding: 14px;
                font-size: 16px;
            }

            .form-meta {
                font-size: 13px;
                margin-bottom: 24px;
            }
        }

        @@media (max-width: 380px) {
            .form-panel {
                padding: 30px 22px;
            }

            .form-title {
                font-size: 22px;
                margin-bottom: 20px;
            }

            .input-row input {
                font-size: 13px;
                padding: 12px 8px 12px 0;
            }

            .input-icon {
                width: 44px;
                font-size: 13px;
            }

            .btn-login {
                padding: 13px;
                font-size: 15px;
                letter-spacing: 1.5px;
            }

            .form-meta {
                font-size: 12px;
            }

            .remember-label input[type="checkbox"] {
                width: 16px;
                height: 16px;
            }

            .alert {
                font-size: 13px;
                padding: 12px 16px;
            }
        }

        /* iPhone-Style Glass Card */
        .page-body {
            padding: 48px 20px;
            background:
                radial-gradient(circle at 14% 12%, rgba(142, 167, 199, 0.14), transparent 38%),
                radial-gradient(circle at 88% 82%, rgba(122, 152, 196, 0.12), transparent 42%),
                #ffffff;
        }

        .login-card {
            width: 100%;
            max-width: 430px;
            min-height: auto;
            padding: 1px;
            border-radius: 34px;
            background: linear-gradient(160deg, rgba(255, 255, 255, 0.96), rgba(240, 247, 255, 0.86));
            border: 1px solid rgba(255, 255, 255, 0.95);
            box-shadow: 0 28px 62px rgba(22, 38, 62, 0.14), 0 8px 22px rgba(22, 38, 62, 0.09), inset 0 1px 0 rgba(255, 255, 255, 0.98);
            backdrop-filter: blur(26px) saturate(160%);
            -webkit-backdrop-filter: blur(26px) saturate(160%);
            display: block;
            overflow: hidden;
            position: relative;
        }

        .login-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(130deg, rgba(255, 255, 255, 0.85) 0%, rgba(255, 255, 255, 0.34) 34%, rgba(255, 255, 255, 0.05) 60%);
            pointer-events: none;
            z-index: 0;
        }

        .login-card::after {
            content: '';
            position: absolute;
            inset: 12px;
            border-radius: 26px;
            background:
                radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.92) 0 10px, rgba(225, 237, 251, 0.78) 11px 14px, rgba(162, 184, 212, 0.46) 15px 18px, rgba(108, 132, 166, 0.26) 19px 21px, transparent 23px),
                radial-gradient(circle at 82% 22%, rgba(255, 255, 255, 0.9) 0 7px, rgba(224, 236, 250, 0.74) 8px 10px, rgba(157, 180, 210, 0.42) 11px 13px, rgba(103, 127, 160, 0.24) 14px 15px, transparent 17px),
                radial-gradient(circle at 80% 78%, rgba(255, 255, 255, 0.9) 0 9px, rgba(221, 235, 251, 0.72) 10px 13px, rgba(154, 177, 207, 0.4) 14px 16px, rgba(98, 122, 154, 0.22) 17px 19px, transparent 21px),
                radial-gradient(circle at 20% 76%, rgba(255, 255, 255, 0.9) 0 8px, rgba(220, 234, 249, 0.71) 9px 11px, rgba(150, 174, 205, 0.38) 12px 14px, rgba(95, 120, 152, 0.2) 15px 17px, transparent 19px);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.52), inset 0 -14px 22px rgba(134, 155, 185, 0.16);
            opacity: 0.74;
            pointer-events: none;
            z-index: 0;
        }

        .form-panel {
            padding: 46px 36px;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(248, 252, 255, 0.88));
            border: 1px solid rgba(255, 255, 255, 0.92);
            border-radius: 33px;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.95), inset 0 -10px 20px rgba(197, 214, 236, 0.18), 0 18px 42px rgba(34, 52, 86, 0.1);
            backdrop-filter: blur(18px) saturate(150%);
            -webkit-backdrop-filter: blur(18px) saturate(150%);
            position: relative;
            z-index: 1;
        }

        .form-panel::before {
            content: '';
            position: absolute;
            top: 2px;
            left: 8%;
            width: 84%;
            height: 1px;
            background: rgba(196, 214, 238, 0.7);
            opacity: 0.9;
            pointer-events: none;
        }

        .form-title {
            color: #14213d;
            text-shadow: 0 1px 0 rgba(255, 255, 255, 0.85);
        }

        .input-row {
            border: 1.4px solid rgba(154, 177, 206, 0.45);
            background: rgba(255, 255, 255, 0.86);
        }

        .input-row:focus-within {
            border-color: #8cb5f1;
            box-shadow: 0 0 0 3px rgba(140, 181, 241, 0.24);
        }

        .input-icon {
            color: #6b7f99;
        }

        .input-row input {
            color: #233142;
        }

        .input-row input::placeholder {
            color: #8fa0b5;
        }

        .password-toggle-btn {
            color: #8fa0b5;
        }

        .password-toggle-btn:hover {
            color: #3d5f93;
        }

        .remember-label {
            color: #3a4c64;
        }

        .forgot-link {
            color: #4e6f9e;
        }

        .forgot-link:hover {
            color: #34537f;
        }

        .btn-login {
            background-image: linear-gradient(135deg, #4f79c9 0%, #5c8ad7 50%, #6f9ee6 100%);
            background-color: transparent;
            box-shadow: 0 10px 22px rgba(68, 108, 178, 0.28);
        }

        .btn-login:hover {
            background-image: linear-gradient(135deg, #456cb4 0%, #527dc5 50%, #628fd5 100%);
            background-color: transparent;
            box-shadow: 0 14px 26px rgba(60, 98, 164, 0.32);
        }

        @@media (max-width: 900px) {
            .login-card {
                max-width: 410px;
            }

            .form-panel {
                padding: 42px 32px;
            }
        }

        @@media (max-width: 768px) {
            .login-card {
                border-radius: 28px;
            }

            .form-panel {
                padding: 38px 28px;
                border-radius: 27px;
            }
        }

        @@media (max-width: 540px) {
            .page-body {
                padding: 20px 15px;
            }

            .form-panel {
                padding: 32px 24px;
            }
        }
    </style>
</head>
<body>
    <div class="page-body">
        <div class="login-card">
            <!-- RIGHT: Login Form -->
            <div class="form-panel">
                <h1 class="form-title">User Login</h1>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <strong><i class="fas fa-exclamation-circle"></i> Error!</strong> @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" asp-controller="Account" asp-action="Login">

                    <!-- Username -->
                    <div class="field-wrapper">
                        <div class="input-row">
                            <span class="input-icon">
                                <i class="fas fa-user"></i>
                            </span>
                            <input type="text"
                                   id="username"
                                   asp-for="Username"
                                   placeholder="Username"
                                   required
                                   autofocus>
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="field-wrapper">
                        <div class="input-row">
                            <span class="input-icon">
                                <i class="fas fa-lock"></i>
                            </span>
                            <input type="password"
                                   id="password"
                                   asp-for="Password"
                                   placeholder="Password"
                                   required>
                            <button type="button" class="password-toggle-btn" onclick="togglePassword()" tabindex="-1">
                                <i class="fas fa-eye" id="toggleIcon"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Remember me + Forgot password -->
                    <div class="form-meta">
                        <label class="remember-label">
                            <input type="checkbox" name="rememberMe" id="rememberMe">
                            Remember
                        </label>
                        <a href="#" class="forgot-link">Forgot password?</a>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn-login">Login</button>

                </form>
            </div>

        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script>
        function togglePassword() {
            const passwordInput = document.getElementById('password');
            const toggleIcon = document.getElementById('toggleIcon');

            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                toggleIcon.classList.remove('fa-eye');
                toggleIcon.classList.add('fa-eye-slash');
            } else {
                passwordInput.type = 'password';
                toggleIcon.classList.remove('fa-eye-slash');
                toggleIcon.classList.add('fa-eye');
            }
        }
    </script>
</body>
</html>
    

