@using System.Text.Json
@using SecurityBase.Core.DTOs
@{
    var userMenusJson = Context.Session.GetString("UserMenus");
    var username = Context.Session.GetString("Username") ?? "User";
    var userRolesJson = Context.Session.GetString("UserRoles");
    var sessionRoles = string.IsNullOrWhiteSpace(userRolesJson)
        ? new List<string>()
        : JsonSerializer.Deserialize<List<string>>(userRolesJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new List<string>();
    var roleDisplay = sessionRoles.FirstOrDefault() ?? "";

    var sessionMenus = string.IsNullOrWhiteSpace(userMenusJson)
        ? new List<MenuDto>()
        : JsonSerializer.Deserialize<List<MenuDto>>(userMenusJson, new JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new List<MenuDto>();

    // Keep only valid routes/menus and order them
    sessionMenus = sessionMenus
        .OrderBy(m => m.DisplayOrder)
        .ThenBy(m => m.MenuName)
        .ToList();

    var parentMenus = sessionMenus.Where(m => (m.ParentMenuId ?? 0) == 0).ToList();
    var childrenByParent = sessionMenus
        .Where(m => (m.ParentMenuId ?? 0) != 0)
        .GroupBy(m => m.ParentMenuId!.Value)
        .ToDictionary(g => g.Key, g => g.OrderBy(x => x.DisplayOrder).ThenBy(x => x.MenuName).ToList());
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SecurityBase</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/grid.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/assignments.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/toasts.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SecurityBase.Mvc.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(ViewData["IsGridPage"] as bool? == true ? "is-grid-page" : "")">
    @await Html.PartialAsync("_Toasts")
    <div class="mobile-header">
        <button class="menu-btn" type="button" onclick="toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>
        <div class="logo">
            <i class="fas fa-shield-alt"></i>
            <span>SecurityBase</span>
        </div>
    </div>

    <div id="sidebar-overlay" class="sidebar-overlay" onclick="closeSidebar()"></div>

    <div id="sidebar" class="sidebar">
        <div class="head-sidebar">
            <div class="sidebar-header" role="button" tabindex="0" onclick="toggleSidebar()" onkeydown="if(event.key==='Enter'||event.key===' ') { event.preventDefault(); toggleSidebar(); }">
                <i class="fas fa-shield-alt"></i><span>SecurityBase</span>
            </div>
            <button type="button" class="sidebar-toggle" onclick="toggleSidebar()">
                <i class="fas fa-bars"></i>
            </button>
        </div>

        @if (sessionMenus != null && sessionMenus.Count > 0)
        {
            foreach (var pm in parentMenus)
            {
                var icon = string.IsNullOrWhiteSpace(pm.Icon) ? "fas fa-folder" : pm.Icon;
                var hasChildren = childrenByParent.ContainsKey(pm.MenuId) && childrenByParent[pm.MenuId].Count > 0;
                var submenuId = $"submenu_{pm.MenuId}";

                if (hasChildren)
                {
                    <div style="position: relative;">
                        <a href="javascript:void(0)" class="menu-item parent-menu" data-menu-id="@submenuId" onclick="toggleSubMenu('@submenuId')">
                            <i class="@icon menu-icon"></i>
                            <span class="menu-text">@pm.MenuName</span>
                            <i class="fas fa-chevron-right menu-chevron"></i>
                        </a>

                        <div id="@submenuId" class="submenu">
                            @foreach (var cm in childrenByParent[pm.MenuId])
                            {
                                var childIcon = string.IsNullOrWhiteSpace(cm.Icon) ? "fas fa-circle" : cm.Icon;
                                <a href="@(string.IsNullOrWhiteSpace(cm.Route) ? "#" : cm.Route)"
                                   class="menu-item submenu-item"
                                   data-parent="@submenuId"
                                   onclick="if(window.innerWidth <= 1024) closeSidebar();">
                                    <i class="@childIcon menu-icon"></i>
                                    <span class="menu-text">@cm.MenuName</span>
                                </a>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <a href="@(string.IsNullOrWhiteSpace(pm.Route) ? "#" : pm.Route)"
                       class="menu-item"
                       onclick="if(window.innerWidth <= 1024) closeSidebar();">
                        <i class="@icon menu-icon"></i>
                        <span class="menu-text">@pm.MenuName</span>
                    </a>
                }
            }
        }
        else
        {
            <!-- Fallback static menu (when session menus are not available) -->
            <a asp-controller="Home" asp-action="Index" class="menu-item" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                <i class="fas fa-chart-line menu-icon"></i>
                <span class="menu-text">Dashboard</span>
            </a>
            <a asp-controller="Users" asp-action="Index" class="menu-item" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                <i class="fas fa-users-cog menu-icon"></i>
                <span class="menu-text">Users</span>
            </a>
            <a asp-controller="Roles" asp-action="Index" class="menu-item" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                <i class="fas fa-user-shield menu-icon"></i>
                <span class="menu-text">Roles</span>
            </a>
            <a asp-controller="Menus" asp-action="Index" class="menu-item" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                <i class="fas fa-layer-group menu-icon"></i>
                <span class="menu-text">Menus</span>
            </a>
            <div style="position: relative;">
                <a href="javascript:void(0)" class="menu-item parent-menu" data-menu-id="assignmentsMenu" onclick="toggleSubMenu('assignmentsMenu')">
                    <i class="fas fa-user-check menu-icon"></i>
                    <span class="menu-text">Assignments</span>
                    <i class="fas fa-chevron-right menu-chevron"></i>
                </a>
                <div id="assignmentsMenu" class="submenu">
                    <a asp-controller="Assignments" asp-action="UserRoles" class="menu-item submenu-item" data-parent="assignmentsMenu" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                        <i class="fas fa-user-tag menu-icon"></i>
                        <span class="menu-text">User Roles</span>
                    </a>
                    <a asp-controller="Assignments" asp-action="RoleMenus" class="menu-item submenu-item" data-parent="assignmentsMenu" onclick="if(window.innerWidth <= 1024) closeSidebar();">
                        <i class="fas fa-list-check menu-icon"></i>
                        <span class="menu-text">Role Menus</span>
                    </a>
                </div>
            </div>
        }

        <div class="sb-sidebar-footer mt-auto">
            <div class="sb-sidebar-user">
                <div class="sb-sidebar-username" title="@username">@username</div>
                @if (!string.IsNullOrWhiteSpace(roleDisplay))
                {
                    <div class="sb-sidebar-role" title="@roleDisplay">@roleDisplay</div>
                }
                else
                {
                    <div class="sb-sidebar-role text-muted" title="No role">No role</div>
                }
            </div>
            <a asp-controller="Account"
               asp-action="Logout"
               class="sb-sidebar-logout"
               title="Logout"
               onclick="if(window.innerWidth <= 1024) closeSidebar();">
                <i class="fas fa-right-from-bracket"></i>
            </a>
        </div>
    </div>

    <div id="content" class="main-content">
        <div class="container-fluid px-4 py-3">
                @* <div class="d-flex justify-content-end mb-3">
                    <div class="d-flex align-items-center bg-white px-3 py-2 rounded-pill shadow-sm">
                        <div class="me-2 bg-primary text-white d-flex align-items-center justify-content-center"
                             style="width: 32px; height: 32px; border-radius: 50%; font-size: 0.85rem;">
                            @(Context.Session.GetString("Username")?[0].ToString().ToUpper() ?? "U")
                        </div>
                        <span class="small fw-bold text-dark me-3">@Context.Session.GetString("Username")</span>
                        <a asp-controller="Account" asp-action="Logout" class="text-danger small text-decoration-none fw-bold" title="Logout">
                            <i class="fas fa-sign-out-alt"></i>
                        </a>
                    </div>
                </div> *@

            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    @await Html.PartialAsync("_ConfirmDialog")

    <script src="~/lib/jquery/dist/jquery.min.js" asp-append-version="true"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/toasts.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <script src="~/js/confirm-modal.js" asp-append-version="true"></script>
    <script src="~/js/form-validation.js" asp-append-version="true"></script>
    <script src="~/js/ui-tooltips.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
