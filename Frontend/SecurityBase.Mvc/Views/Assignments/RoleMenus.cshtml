@{
    ViewData["Title"] = "Role Menu Assignment";
    ViewData["IsGridPage"] = true;
}

<div class="container-fluid p-2 grid-page">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary"><i class="fas fa-compass me-2"></i>Role Menu Assignment</h2>
        </div>
        <div class="col-md-6 text-end">
            <div class="patient-table-actions">
                <div class="searchbar" style="display:inline-block;">
                    <div class="searchbar-wrapper">
                        <div class="searchbar-left">
                            <div class="search-icon-wrapper">
                                <span class="search-icon searchbar-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                        <div class="searchbar-center">
                            <div class="searchbar-input-spacer"></div>
                            <input type="text" id="assignmentRoleSearch" class="searchbar-input" maxlength="2048" autocapitalize="off" autocomplete="off" title="Search" role="combobox" placeholder="Search roles...">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-2 sb-assignment-body">
        <div class="col-lg-4 d-flex">
            <div class="patient-table-responsive shadow-sm grid-card w-100">
                <div class="sb-assignment-card-header">
                    <div class="sb-assignment-card-title"><i class="fas fa-user-tag"></i>Roles</div>
                </div>
                <div class="grid-table-wrap">
                    <table class="patient-table" id="rolesPickTable">
                        <thead>
                            <tr>
                                <th style="width: 45%;">Role</th>
                                <th style="width: 55%;">Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in ViewBag.Roles)
                            {
                                <tr id="roleRow_@role.RoleId" class="sb-assignment-user-row" onclick="selectRole(@role.RoleId, '@role.RoleName', this)">
                                    <td><i class="fas fa-shield-alt text-muted me-2"></i><span class="fw-bold text-dark">@role.RoleName</span></td>
                                    <td><span class="text-muted">@role.Description</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="patient-table-pagination-bar">
                    <div class="pagination-info">
                        Showing <span id="rolesShownCount">0</span> roles
                    </div>
                    <div class="pagination-controls">
                        <select class="page-size-selector" id="rolesPageSize">
                            <option value="10" selected>10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="-1">All</option>
                        </select>
                        <div class="button-container">
                            <button class="button-3d" id="rolesPrevBtn" type="button">
                                <div class="button-top">&#10094;</div>
                                <div class="button-bottom"></div>
                                <div class="button-base"></div>
                            </button>
                            <span class="page-number" id="rolesPageNumber">Page 1 of 1</span>
                            <button class="button-3d" id="rolesNextBtn" type="button">
                                <div class="button-top">&#10095;</div>
                                <div class="button-bottom"></div>
                                <div class="button-base"></div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8 d-flex">
            <div id="roleMenuCard" class="patient-table-responsive shadow-sm grid-card w-100 d-none">
                <div class="sb-assignment-card-header">
                    <div class="sb-assignment-card-title">
                        <i class="fas fa-list-check"></i>
                        Menus for <span id="selectedRoleName" class="sb-assignment-selected-user"></span>
                    </div>
                </div>
                <div class="grid-table-wrap">
                    <table class="patient-table" id="roleMenusAssignTable">
                        <thead>
                            <tr>
                                <th style="width: 40%;">Menu</th>
                                <th style="width: 50%;">Route</th>
                                <th style="width: 10%;">Assigned</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var menu in ViewBag.Menus)
                            {
                                <tr>
                                    <td>
                                        <i class="@(string.IsNullOrWhiteSpace(menu.Icon) ? "fas fa-folder" : menu.Icon) text-muted me-2"></i>
                                        <span class="fw-bold text-dark">@menu.MenuName</span>
                                    </td>
                                    <td><code class="text-primary">@menu.Route</code></td>
                                    <td class="text-end">
                                        <div class="form-check form-switch sb-assignment-switch">
                                            <input class="form-check-input role-menu-checkbox" type="checkbox" id="menu_@menu.MenuId" onchange="toggleRoleMenu(@menu.MenuId)">
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="patient-table-pagination-bar">
                    <div class="pagination-info">
                        Showing <span id="assignShownCount">0</span> menus
                    </div>
                    <div class="pagination-controls">
                        <select class="page-size-selector" id="assignPageSize">
                            <option value="15" selected>15</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="-1">All</option>
                        </select>
                        <div class="button-container">
                            <button class="button-3d" id="assignPrevBtn" type="button">
                                <div class="button-top">&#10094;</div>
                                <div class="button-bottom"></div>
                                <div class="button-base"></div>
                            </button>
                            <span class="page-number" id="assignPageNumber">Page 1 of 1</span>
                            <button class="button-3d" id="assignNextBtn" type="button">
                                <div class="button-top">&#10095;</div>
                                <div class="button-bottom"></div>
                                <div class="button-base"></div>
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="noRoleSelected" class="patient-table-responsive shadow-sm grid-card w-100">
                <div class="sb-assignment-placeholder">
                    <div>
                        <div class="icon"><i class="fas fa-stream"></i></div>
                        <h4 class="fw-bold text-dark">No Role Selected</h4>
                        <p class="text-muted mb-0">Select a role from the left to manage menu assignments.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentRoleId = 0;
        let rolesPage = 1;
        let assignPage = 1;

        function selectRole(roleId, roleName, rowEl) {
            currentRoleId = roleId;
            $('#selectedRoleName').text(roleName);
            $('#noRoleSelected').addClass('d-none');
            $('#roleMenuCard').removeClass('d-none');
            $('#rolesPickTable tbody tr').removeClass('sb-selected');
            if (rowEl) $(rowEl).addClass('sb-selected');
            ensureRoleRowVisible(rowEl);

            $('.role-menu-checkbox').prop('checked', false);

            $.get('/Assignments/GetRoleMenus?roleId=' + roleId, function (response) {
                if (response && response.success && response.data) {
                    response.data.forEach(menu => {
                        $('#menu_' + menu.menuId).prop('checked', true);
                    });
                }
            });
        }

        function toggleRoleMenu(menuId) {
            const isChecked = $('#menu_' + menuId).is(':checked');
            if (!currentRoleId) {
                $('#menu_' + menuId).prop('checked', false);
                return;
            }

            if (isChecked) {
                $.post('/Assignments/AssignRoleMenu', { roleId: currentRoleId, menuId: menuId }, function (response) {
                    if (!response || !response.success) {
                        if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Assign failed.');
                        $('#menu_' + menuId).prop('checked', false);
                    }
                });
            } else {
                $.post('/Assignments/RevokeRoleMenu', { roleId: currentRoleId, menuId: menuId }, function (response) {
                    if (!response || !response.success) {
                        if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Revoke failed.');
                        $('#menu_' + menuId).prop('checked', true);
                    }
                });
            }
        }

        function getFilteredRoleRows() {
            var q = (($('#assignmentRoleSearch').val() || '') + '').toLowerCase();
            var rows = $('#rolesPickTable tbody tr').toArray();
            if (!q) return rows;
            return rows.filter(function (tr) {
                var txt = ($(tr).text() || '').toLowerCase();
                return txt.indexOf(q) > -1;
            });
        }

        function applyRolesPagination(resetToFirstPage) {
            var rows = getFilteredRoleRows();
            var pageSizeRaw = parseInt($('#rolesPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;

            if (resetToFirstPage) rolesPage = 1;

            var total = rows.length;
            var totalPages = pageSize > 0 ? Math.max(1, Math.ceil(total / pageSize)) : 1;
            rolesPage = Math.min(Math.max(1, rolesPage), totalPages);

            $('#rolesPickTable tbody tr').hide();
            var visible = rows;
            if (pageSize > 0) {
                var start = (rolesPage - 1) * pageSize;
                visible = rows.slice(start, start + pageSize);
            }
            visible.forEach(function (tr) { $(tr).show(); });

            $('#rolesShownCount').text(visible.length);
            $('#rolesPageNumber').text('Page ' + rolesPage + ' of ' + totalPages);
            $('#rolesPrevBtn').prop('disabled', rolesPage <= 1);
            $('#rolesNextBtn').prop('disabled', rolesPage >= totalPages);
        }

        function ensureRoleRowVisible(rowEl) {
            if (!rowEl) return;
            var rows = getFilteredRoleRows();
            var idx = rows.indexOf(rowEl);
            if (idx < 0) return;
            var pageSizeRaw = parseInt($('#rolesPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;
            if (pageSize <= 0) return;
            rolesPage = Math.floor(idx / pageSize) + 1;
            applyRolesPagination(false);
        }

        function applyAssignPagination(resetToFirstPage) {
            var rows = $('#roleMenusAssignTable tbody tr').toArray();
            var pageSizeRaw = parseInt($('#assignPageSize').val() || '15', 10);
            var pageSize = isNaN(pageSizeRaw) ? 15 : pageSizeRaw;

            if (resetToFirstPage) assignPage = 1;

            var total = rows.length;
            var totalPages = pageSize > 0 ? Math.max(1, Math.ceil(total / pageSize)) : 1;
            assignPage = Math.min(Math.max(1, assignPage), totalPages);

            $('#roleMenusAssignTable tbody tr').hide();
            var visible = rows;
            if (pageSize > 0) {
                var start = (assignPage - 1) * pageSize;
                visible = rows.slice(start, start + pageSize);
            }
            visible.forEach(function (tr) { $(tr).show(); });

            $('#assignShownCount').text(visible.length);
            $('#assignPageNumber').text('Page ' + assignPage + ' of ' + totalPages);
            $('#assignPrevBtn').prop('disabled', assignPage <= 1);
            $('#assignNextBtn').prop('disabled', assignPage >= totalPages);
        }

        $('#assignmentRoleSearch').on('keyup', function () { applyRolesPagination(true); });
        $('#rolesPageSize').on('change', function () { applyRolesPagination(true); });
        $('#assignPageSize').on('change', function () { applyAssignPagination(true); });

        $('#rolesPrevBtn').on('click', function () { rolesPage = Math.max(1, rolesPage - 1); applyRolesPagination(false); });
        $('#rolesNextBtn').on('click', function () { rolesPage = rolesPage + 1; applyRolesPagination(false); });

        $('#assignPrevBtn').on('click', function () { assignPage = Math.max(1, assignPage - 1); applyAssignPagination(false); });
        $('#assignNextBtn').on('click', function () { assignPage = assignPage + 1; applyAssignPagination(false); });

        $(document).ready(function () {
            applyRolesPagination(true);
            applyAssignPagination(true);
        });
    </script>
}
