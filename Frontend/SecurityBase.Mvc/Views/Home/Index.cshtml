@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid p-4">
    <div class="row mb-4">
        <div class="col-12 text-center">
            <h1 class="fw-bold text-primary mb-2">Welcome to SecurityBase</h1>
            <p class="text-muted fs-5">Manage your system security and access control from one central hub.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <a asp-controller="Users" asp-action="Index" class="text-decoration-none h-100">
                <div class="dashboard-card p-4 rounded-4 shadow-sm h-100 border-0 bg-white text-center transition-all">
                    <div class="dashboard-icon bg-primary-subtle text-primary mb-3">
                        <i class="fas fa-users fa-2x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Users</h5>
                    <p class="small text-muted mb-0">Manage system users, status, and authentication.</p>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Roles" asp-action="Index" class="text-decoration-none h-100">
                <div class="dashboard-card p-4 rounded-4 shadow-sm h-100 border-0 bg-white text-center transition-all">
                    <div class="dashboard-icon bg-success-subtle text-success mb-3">
                        <i class="fas fa-user-shield fa-2x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Roles</h5>
                    <p class="small text-muted mb-0">Define organizational roles and permissions.</p>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Menus" asp-action="Index" class="text-decoration-none h-100">
                <div class="dashboard-card p-4 rounded-4 shadow-sm h-100 border-0 bg-white text-center transition-all">
                    <div class="dashboard-icon bg-info-subtle text-info mb-3">
                        <i class="fas fa-layer-group fa-2x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Menus</h5>
                    <p class="small text-muted mb-0">Control navigation and access endpoints.</p>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-controller="Assignments" asp-action="UserRoles" class="text-decoration-none h-100">
                <div class="dashboard-card p-4 rounded-4 shadow-sm h-100 border-0 bg-white text-center transition-all">
                    <div class="dashboard-icon bg-warning-subtle text-warning mb-3">
                        <i class="fas fa-tasks fa-2x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Assignments</h5>
                    <p class="small text-muted mb-0">Bridge users with their roles and menus.</p>
                </div>
            </a>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-gradient-primary text-white p-4 text-center border-0">
                    <h4 class="mb-0 fw-bold">System Status</h4>
                </div>
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="spinner-grow text-success me-2" role="status" style="width: 1rem; height: 1rem;"></div>
                        <span class="fw-bold text-success">API Connection Active</span>
                    </div>
                    <div class="row text-center g-4">
                        <div class="col-4 border-end">
                            <h2 class="fw-bold text-primary mb-0">v1.2</h2>
                            <span class="small text-muted">Version</span>
                        </div>
                        <div class="col-4 border-end">
                            <h2 class="fw-bold text-primary mb-0">100%</h2>
                            <span class="small text-muted">Uptime</span>
                        </div>
                        <div class="col-4">
                            <h2 class="fw-bold text-primary mb-0">Fast</h2>
                            <span class="small text-muted">Latency</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .dashboard-icon {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }
    .dashboard-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
    }
    .bg-gradient-primary { background: var(--primary-gradient); }
    .transition-all { transition: all 0.3s ease; }
</style>
