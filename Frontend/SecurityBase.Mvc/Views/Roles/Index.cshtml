@using SecurityBase.Mvc.Helpers
@{
    ViewData["Title"] = "Role Management";
    var permissions = MenuPermissionHelper.GetMenuPermissions(Context, "/Roles/Index");
}

<div class="container-fluid p-2 grid-page">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2 class="fw-bold text-primary"><i class="fas fa-user-tag me-2"></i>Role Management</h2>
        </div>
        <div class="col-md-6 text-end">
            <div class="patient-table-actions">
                <div class="searchbar" style="display:inline-block;">
                    <div class="searchbar-wrapper">
                        <div class="searchbar-left">
                            <div class="search-icon-wrapper">
                                <span class="search-icon searchbar-icon">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>

                        <div class="searchbar-center">
                            <div class="searchbar-input-spacer"></div>
                            <input type="text" id="roleSearch" class="searchbar-input" maxlength="2048" autocapitalize="off" autocomplete="off" title="Search" role="combobox" placeholder="Search roles...">
                        </div>
                    </div>
                </div>
                <button class="button" type="button"><i class="fa-solid fa-file-export pe-1"></i> Export</button>
                @if (permissions.CanCreate)
                {
                    <button class="button" type="button" onclick="openCreateModal()">
                        <i class="fa-solid fa-plus pe-1"></i> Add Role
                    </button>
                }
            </div>
        </div>
    </div>

    <div class="patient-table-responsive shadow-sm grid-card">
        <div class="grid-table-wrap">
        <table class="patient-table" id="rolesTable">
            <thead>
                <tr>
                    <th style="width: 30%;">Role Name</th>
                    <th style="width: 50%;">Description</th>
                    @if (permissions.CanEdit || permissions.CanDelete)
                    {
                        <th style="width: 20%;">Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td colspan="@(permissions.CanEdit || permissions.CanDelete ? 3 : 2)" class="text-center p-5">
                        <div class="text-muted">
                            <i class="fas fa-spinner fa-spin fa-2x mb-3"></i>
                            <p class="mb-0">Loading roles...</p>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
        </div>
        <div class="patient-table-pagination-bar">
            <div class="pagination-info">
                Showing <span id="rolesShownCount">0</span> entries
            </div>
            <div class="pagination-controls">
                <select class="page-size-selector" id="rolesPageSize">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                    <option value="-1">All</option>
                </select>
                <button class="button-3d" onclick="loadRoles()" title="Refresh">
                    <div class="button-top">
                        <span class="material-icons"><i class="fas fa-sync-alt m-0"></i></span>
                    </div>
                    <div class="button-bottom"></div>
                    <div class="button-base"></div>
                </button>
                <div class="button-container">
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10094;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                    <span class="page-number">Page 1 of 1</span>
                    <button class="button-3d" disabled>
                        <div class="button-top">&#10095;</div>
                        <div class="button-bottom"></div>
                        <div class="button-base"></div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade sb-modal" id="roleModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header sb-form-modal-header">
                <div>
                    <h5 class="modal-title" id="modalTitle">Add New Role</h5>
                    <div class="sb-form-modal-subtitle">Define role name and description</div>
                </div>
                <button type="button" class="btn-close" aria-label="Close" data-sb-modal-close></button>
            </div>
            <div class="modal-body p-4 sb-form-modal-body">
                <form id="roleForm" class="sb-form" novalidate>
                    <input type="hidden" id="roleId" name="RoleId" />
                    <div class="form-section mb-0">
                        <div class="section-title">
                            <i class="fas fa-shield-alt section-icon"></i>
                            Role Details
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">
                                    Role Name <span class="text-danger">*</span>
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="2–60 characters." aria-label="Role name requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-tag input-icon"></i>
                                    <input type="text" class="form-control" id="roleName" name="RoleName" placeholder="e.g. Admin" required>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="form-label">
                                    Description
                                    <button type="button" class="sb-info-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="Optional. Max 250 characters." aria-label="Description requirements">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </label>
                                <div class="input-with-icon">
                                    <i class="fas fa-align-left input-icon"></i>
                                    <textarea class="form-control" id="description" name="Description" rows="3" placeholder="Optional description"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer sb-form-actions">
                <div class="sb-form w-100 d-flex justify-content-end align-items-center gap-2">
                    <button type="button" class="btn-cancel" data-sb-modal-close>
                        <span>CANCEL</span>
                    </button>
                    <button type="button" class="btn-save" onclick="saveRole()">
                        <span class="shadow"></span>
                        <span class="edge"></span>
                        <span class="front"><span>SAVE</span></span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allRoles = [];
        var canEdit = @(permissions.CanEdit ? "true" : "false");
        var canDelete = @(permissions.CanDelete ? "true" : "false");
        var hasActions = canEdit || canDelete;
        var colSpan = hasActions ? 3 : 2;

        function loadRoles() {
            $.ajax({
                url: '/Roles/GetAllRoles',
                type: 'GET',
                success: function (response) {
                    allRoles = response.data || [];
                    applyRolesGrid();
                },
                error: function () {
                    $('#rolesTable tbody').html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-exclamation-triangle fa-2x mb-3"></i><p>Failed to load roles.</p></div></td></tr>');
                }
            });
        }

        function renderRolesTable(roles) {
            var $tbody = $('#rolesTable tbody');
            $tbody.empty();

            if (!roles || roles.length === 0) {
                $tbody.html('<tr><td colspan="' + colSpan + '" class="text-center p-5"><div class="text-muted"><i class="fas fa-search fa-2x mb-3"></i><p class="mb-0">No roles found.</p></div></td></tr>');
                return;
            }

            $.each(roles, function (i, role) {
                var roleId = role.roleId || role.RoleId || 0;
                var roleName = role.roleName || role.RoleName || '';
                var description = role.description || role.Description || '';

                var row = '<tr>';
                row += '<td><i class="fas fa-shield-alt text-muted me-2"></i><span class="fw-bold text-dark">' + $('<span>').text(roleName).html() + '</span></td>';
                row += '<td><span class="text-muted">' + $('<span>').text(description).html() + '</span></td>';

                if (hasActions) {
                    row += '<td>';
                    if (canEdit) {
                        row += '<button onclick=\'editRole(' + JSON.stringify(role) + ')\' class="patient-table-action patient-table-edit" title="Edit"><i class="fas fa-edit"></i></button>';
                    }
                    if (canDelete) {
                        row += '<button onclick="deleteRole(' + roleId + ')" class="patient-table-action patient-table-delete" title="Delete"><i class="fas fa-trash"></i></button>';
                    }
                    row += '</td>';
                }
                row += '</tr>';
                $tbody.append(row);
            });
        }

        function applyRolesGrid() {
            var query = (($('#roleSearch').val() || '') + '').toLowerCase();
            var pageSizeRaw = parseInt($('#rolesPageSize').val() || '10', 10);
            var pageSize = isNaN(pageSizeRaw) ? 10 : pageSizeRaw;

            var filtered = allRoles.filter(function (r) {
                if (!query) return true;
                var text = ((r.roleName || r.RoleName || '') + ' ' + (r.description || r.Description || '')).toLowerCase();
                return text.indexOf(query) > -1;
            });

            if (pageSize > 0) {
                filtered = filtered.slice(0, pageSize);
            }

            renderRolesTable(filtered);
            $('#rolesShownCount').text(filtered.length);
        }

        function openCreateModal() {
            $('#modalTitle').text('Add New Role');
            $('#roleForm')[0].reset();
            $('#roleId').val(0);
            $('#roleModal').modal('show');
        }

        function editRole(role) {
            var roleId = role && role.roleId != null ? role.roleId : (role && role.RoleId != null ? role.RoleId : 0);
            var roleName = role && role.roleName != null ? role.roleName : (role && role.RoleName != null ? role.RoleName : '');
            var description = role && role.description != null ? role.description : (role && role.Description != null ? role.Description : '');

            $('#modalTitle').text('Edit Role');
            $('#roleId').val(roleId);
            $('#roleName').val(roleName);
            $('#description').val(description);
            $('#roleModal').modal('show');
        }

        function saveRole() {
            if (window.SBFormValidation && !window.SBFormValidation.validateRoleForm()) return;
            var formData = $('#roleForm').serialize();

            $.post('/Roles/SaveRole', formData, function (response) {
                if (response && response.success) {
                    if (window.SBToast) window.SBToast.success((response.message || 'Saved.'));
                    if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.allowCloseOnce('roleModal');
                    loadRoles();
                    $('#roleModal').modal('hide');
                } else {
                    if (window.SBToast) window.SBToast.error((response && response.message) ? response.message : 'Save failed.');
                }
            });
        }

        function deleteRole(id) {
            if (!window.SBToast || !window.SBToast.confirm) return;

            window.SBToast.confirm({ title: 'Delete role', message: "Delete this role? This may affect permissions.", variant: 'danger', confirmText: 'Delete' })
                .then(function (ok) {
                    if (!ok) return;
                    $.ajax({
                        url: '/Roles/DeleteRole/' + id,
                        type: 'DELETE',
                        success: function (response) {
                            if (response && response.success) {
                                window.SBToast.success((response.message || 'Deleted.'));
                                loadRoles();
                            } else {
                                window.SBToast.error((response && response.message) ? response.message : 'Delete failed.');
                            }
                        }
                    });
                });
        }

        $('#roleSearch').on('keyup', applyRolesGrid);
        $('#rolesPageSize').on('change', applyRolesGrid);
        $(document).ready(function () {
            if (window.SBModalDirtyGuard) window.SBModalDirtyGuard.attach({ modalId: 'roleModal', formId: 'roleForm' });
            loadRoles();
        });
    </script>
}
